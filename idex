<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
  <title>Vein — Think deeper</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0e0e12;
      --surface: #13131a;
      --surface2: #1a1a24;
      --border: rgba(255,255,255,0.06);
      --accent: #8b3a3a;
      --accent-dim: rgba(139,58,58,0.15);
      --accent-glow: rgba(139,58,58,0.08);
      --text: #f0ede8;
      --muted: rgba(240,237,232,0.38);
      --muted2: rgba(240,237,232,0.18);
      --vein-msg: #16141c;
      --devil: #8b3a3a;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Mono', monospace;
      font-weight: 300;
      overflow: hidden;
    }

    /* ======================== LAYOUT ======================== */
    .app {
      display: grid;
      grid-template-columns: 240px 1fr;
      height: 100vh;
      height: 100dvh;
    }

    /* ======================== SIDEBAR ======================== */
    .sidebar {
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
    }

    .sidebar-header {
      padding: 32px 24px 24px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .logo {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: 26px;
      letter-spacing: 0.08em;
      color: var(--text);
      display: flex;
      align-items: baseline;
      gap: 2px;
    }

    .logo-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      margin-left: 2px;
      margin-bottom: 4px;
      flex-shrink: 0;
    }

    .logo-sub {
      margin-top: 6px;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .sidebar-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 20px 0 0;
    }

    .sidebar-scroll::-webkit-scrollbar { width: 0; }

    .sidebar-section {
      padding: 0 20px 20px;
    }

    .sidebar-label {
      font-size: 9px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted2);
      margin-bottom: 10px;
      padding: 0 4px;
    }

    .mode-list {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .mode-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: 3px;
      border: none;
      background: transparent;
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 300;
      cursor: pointer;
      text-align: left;
      transition: all 0.15s;
      letter-spacing: 0.02em;
      width: 100%;
    }

    .mode-btn:hover:not(.active) {
      background: rgba(255,255,255,0.03);
      color: var(--text);
    }

    .mode-btn.active {
      background: var(--accent-dim);
      color: var(--text);
      border-left: 2px solid var(--accent);
      padding-left: 10px;
    }

    .mode-icon {
      font-size: 13px;
      width: 16px;
      text-align: center;
      flex-shrink: 0;
    }

    .mode-devil-sep {
      height: 1px;
      background: var(--border);
      margin: 8px 12px;
    }

    .mode-btn.devil {
      color: rgba(139,58,58,0.5);
    }

    .mode-btn.devil:hover:not(.active) {
      background: rgba(139,58,58,0.06);
      color: var(--accent);
    }

    .mode-btn.devil.active {
      background: rgba(139,58,58,0.12);
      border-left: 2px solid var(--accent);
      color: var(--accent);
      padding-left: 10px;
    }

    .sidebar-divider {
      height: 1px;
      background: var(--border);
      margin: 4px 20px 20px;
    }

    .session-summary {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.7;
      padding: 0 4px;
      font-style: italic;
    }

    .sidebar-footer {
      padding: 16px 20px;
      border-top: 1px solid var(--border);
      flex-shrink: 0;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 12px;
    }

    .stat-box {
      background: var(--surface2);
      border-radius: 4px;
      padding: 10px 10px 8px;
    }

    .stat-label {
      font-size: 9px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted2);
      margin-bottom: 4px;
    }

    .stat-val {
      font-size: 16px;
      font-weight: 400;
      color: var(--text);
    }

    .footer-btns {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .footer-btn {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 3px;
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      padding: 7px 12px;
      cursor: pointer;
      text-align: left;
      letter-spacing: 0.06em;
      transition: all 0.15s;
    }

    .footer-btn:hover {
      border-color: rgba(255,255,255,0.12);
      color: var(--text);
    }

    /* ======================== MAIN ======================== */
    .main {
      display: flex;
      flex-direction: column;
      height: 100vh;
      height: 100dvh;
      overflow: hidden;
      background: var(--bg);
    }

    /* Subtle noise texture on bg */
    .main::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.4;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 24px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      position: relative;
      z-index: 1;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    /* Mobile menu button */
    .menu-btn {
      display: none;
      background: transparent;
      border: none;
      color: var(--muted);
      cursor: pointer;
      padding: 4px;
      font-size: 18px;
      line-height: 1;
    }

    .topbar-info {}

    .topbar-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 15px;
      font-weight: 400;
      letter-spacing: 0.04em;
      color: var(--text);
    }

    .topbar-sub {
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.06em;
      margin-top: 2px;
    }

    .status-pill {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.08em;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 5px 10px;
    }

    .status-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--accent);
      animation: pulse 2.5s ease infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.8); }
    }

    /* ======================== CHAT ======================== */
    .chat-area {
      flex: 1;
      overflow-y: auto;
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      gap: 24px;
      position: relative;
      z-index: 1;
      scroll-behavior: smooth;
    }

    .chat-area::-webkit-scrollbar { width: 0; }

    /* Welcome */
    .welcome {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      min-height: 100%;
      padding: 40px 20px;
      gap: 20px;
    }

    .welcome-symbol {
      font-family: 'Cormorant Garamond', serif;
      font-size: 48px;
      color: var(--accent);
      opacity: 0.6;
      font-style: italic;
      line-height: 1;
      animation: float 4s ease-in-out infinite;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); opacity: 0.6; }
      50% { transform: translateY(-6px); opacity: 0.9; }
    }

    .welcome-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(22px, 5vw, 30px);
      font-weight: 300;
      letter-spacing: 0.04em;
      color: var(--text);
    }

    .welcome-sub {
      font-size: clamp(11px, 2.5vw, 13px);
      color: var(--muted);
      line-height: 1.8;
      max-width: 380px;
      letter-spacing: 0.02em;
    }

    .starters {
      display: flex;
      flex-direction: column;
      gap: 8px;
      width: 100%;
      max-width: 420px;
      margin-top: 8px;
    }

    .starter-btn {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 14px 16px;
      text-align: left;
      cursor: pointer;
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 300;
      line-height: 1.6;
      transition: all 0.2s;
      letter-spacing: 0.02em;
    }

    .starter-btn:hover {
      border-color: rgba(139,58,58,0.3);
      background: var(--accent-glow);
      color: var(--text);
    }

    .starter-tag {
      display: inline-block;
      font-size: 9px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 6px;
      opacity: 0.7;
    }

    /* Messages */
    .msg {
      display: flex;
      gap: 14px;
      max-width: 680px;
      animation: msgIn 0.25s ease;
    }

    @keyframes msgIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .msg.user { align-self: flex-end; flex-direction: row-reverse; }
    .msg.vein { align-self: flex-start; }

    .msg-avatar {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      letter-spacing: 0.05em;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .msg.vein .msg-avatar {
      background: var(--accent-dim);
      border: 1px solid rgba(139,58,58,0.25);
      color: var(--accent);
      font-family: 'Cormorant Garamond', serif;
      font-size: 14px;
      font-style: italic;
    }

    .msg.user .msg-avatar {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 9px;
    }

    .msg-body {}

    .msg-name {
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted2);
      margin-bottom: 6px;
    }

    .msg.user .msg-name { text-align: right; }

    .msg-bubble {
      padding: 14px 18px;
      border-radius: 4px;
      font-size: 13px;
      line-height: 1.75;
      letter-spacing: 0.01em;
    }

    .msg.vein .msg-bubble {
      background: var(--vein-msg);
      border: 1px solid var(--border);
      border-left: 2px solid rgba(139,58,58,0.3);
      color: var(--text);
    }

    .msg.user .msg-bubble {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: rgba(240,237,232,0.75);
    }

    .observation-pill {
      display: block;
      margin-top: 10px;
      padding: 8px 12px;
      background: rgba(139,58,58,0.08);
      border-left: 2px solid rgba(139,58,58,0.4);
      border-radius: 2px;
      font-size: 11px;
      color: rgba(139,58,58,0.8);
      font-style: italic;
      line-height: 1.6;
    }

    /* Typing */
    .typing-dots {
      display: flex;
      gap: 5px;
      padding: 18px 18px;
      background: var(--vein-msg);
      border: 1px solid var(--border);
      border-left: 2px solid rgba(139,58,58,0.3);
      border-radius: 4px;
      width: fit-content;
    }

    .typing-dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--accent);
      opacity: 0.4;
      animation: typingPulse 1.2s ease infinite;
    }

    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }

    @keyframes typingPulse {
      0%, 100% { opacity: 0.2; transform: scale(0.8); }
      50% { opacity: 1; transform: scale(1.2); }
    }

    /* ======================== INPUT ======================== */
    .input-zone {
      padding: 16px 24px 20px;
      border-top: 1px solid var(--border);
      flex-shrink: 0;
      position: relative;
      z-index: 1;
      background: var(--bg);
    }

    .input-row {
      display: flex;
      gap: 10px;
      align-items: flex-end;
    }

    .input-field {
      flex: 1;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 12px 16px;
      color: var(--text);
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      font-weight: 300;
      resize: none;
      outline: none;
      min-height: 46px;
      max-height: 140px;
      transition: border-color 0.2s;
      line-height: 1.6;
      letter-spacing: 0.01em;
    }

    .input-field::placeholder { color: var(--muted2); }

    .input-field:focus {
      border-color: rgba(139,58,58,0.35);
    }

    .send-btn {
      width: 46px;
      height: 46px;
      border-radius: 4px;
      background: var(--accent);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.15s;
      color: var(--text);
      font-size: 18px;
    }

    .send-btn:hover { background: #a04444; transform: scale(1.03); }
    .send-btn:disabled { background: var(--surface2); cursor: not-allowed; transform: none; opacity: 0.5; }

    .input-hint {
      font-size: 10px;
      color: var(--muted2);
      margin-top: 8px;
      text-align: center;
      letter-spacing: 0.06em;
    }

    /* ======================== VOICE ======================== */
    .voice-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 10px;
    }
    .mic-btn {
      width: 40px; height: 40px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--muted);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
      transition: all 0.2s;
    }
    .mic-btn:hover { border-color: rgba(139,58,58,0.4); color: var(--text); }
    .mic-btn.listening {
      background: rgba(139,58,58,0.15);
      border-color: rgba(139,58,58,0.6);
      color: var(--accent);
      animation: micPulse 1.4s ease infinite;
    }
    @keyframes micPulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(139,58,58,0.3); }
      50% { box-shadow: 0 0 0 8px rgba(139,58,58,0); }
    }
    .mic-label {
      font-size: 10px; color: var(--muted2);
      letter-spacing: 0.08em; flex: 1; transition: color 0.2s;
    }
    .mic-label.active { color: rgba(139,58,58,0.7); }
    .voice-toggle {
      display: flex; align-items: center; gap: 6px;
      cursor: pointer; padding: 5px 12px;
      border: 1px solid var(--border); border-radius: 20px;
      background: transparent; transition: all 0.2s; flex-shrink: 0;
    }
    .voice-toggle:hover { border-color: rgba(139,58,58,0.3); }
    .voice-toggle.on { border-color: rgba(139,58,58,0.4); background: rgba(139,58,58,0.07); }
    .toggle-icon { font-size: 13px; }
    .toggle-label {
      font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--muted); font-family: 'DM Mono', monospace;
    }
    .voice-toggle.on .toggle-label { color: rgba(139,58,58,0.7); }

    /* ======================== OVERLAY ======================== */
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(14,14,18,0.96);
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }

    .overlay.open {
      opacity: 1;
      pointer-events: all;
    }

    .overlay-card {
      background: var(--surface);
      border: 1px solid rgba(139,58,58,0.2);
      border-radius: 6px;
      padding: clamp(32px, 8vw, 48px) clamp(24px, 6vw, 40px);
      max-width: 420px;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 16px;
    }

    .overlay-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 32px;
      font-weight: 600;
      letter-spacing: 0.1em;
      color: var(--text);
    }

    .overlay-logo span {
      color: var(--accent);
    }

    .overlay-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 18px;
      font-weight: 300;
      color: var(--text);
      letter-spacing: 0.04em;
    }

    .overlay-sub {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.8;
      letter-spacing: 0.02em;
    }

    .overlay-input {
      width: 100%;
      padding: 13px 16px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--text);
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      outline: none;
      transition: border-color 0.2s;
      text-align: center;
      letter-spacing: 0.04em;
    }

    .overlay-input:focus { border-color: rgba(139,58,58,0.4); }

    .overlay-error {
      font-size: 11px;
      color: var(--accent);
      display: none;
      letter-spacing: 0.04em;
    }

    .overlay-btn {
      width: 100%;
      padding: 14px;
      background: var(--accent);
      color: var(--text);
      border: none;
      border-radius: 4px;
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.1em;
      cursor: pointer;
      transition: background 0.15s;
    }

    .overlay-btn:hover { background: #a04444; }

    .overlay-link {
      font-size: 11px;
      color: rgba(139,58,58,0.5);
      text-decoration: none;
      letter-spacing: 0.04em;
      transition: color 0.15s;
    }

    .overlay-link:hover { color: var(--accent); }

    /* ======================== DEPTH BAR ======================== */
    .depth-bar-wrap {
      margin-bottom: 10px;
    }

    .depth-bar-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }

    .depth-bar-label {
      font-size: 9px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted2);
    }

    .depth-bar-val {
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.04em;
    }

    .depth-bar-track {
      height: 3px;
      background: var(--surface2);
      border-radius: 2px;
      overflow: hidden;
    }

    .depth-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, rgba(139,58,58,0.4), var(--accent));
      border-radius: 2px;
      width: 0%;
      transition: width 0.8s cubic-bezier(0.4,0,0.2,1);
    }

    .depth-bar-milestone {
      font-size: 10px;
      color: var(--accent);
      margin-top: 5px;
      letter-spacing: 0.06em;
      min-height: 14px;
      font-style: italic;
    }

    /* ======================== INSIGHT MODAL ======================== */
    .insight-card {
      max-width: 500px;
      text-align: left;
      align-items: flex-start;
      gap: 20px;
    }

    .insight-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
    }

    .insight-week {
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .insight-streak {
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.06em;
    }

    .insight-body {
      width: 100%;
      font-family: 'Cormorant Garamond', serif;
      font-size: 17px;
      font-weight: 300;
      line-height: 1.8;
      color: var(--text);
      font-style: italic;
      min-height: 80px;
    }

    .insight-loading {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px 0;
    }

    /* ======================== WEEKLY QUESTION ======================== */
    .weekly-q {
      font-family: 'Cormorant Garamond', serif;
      font-size: 20px;
      font-weight: 300;
      line-height: 1.6;
      color: var(--text);
      font-style: italic;
      width: 100%;
      text-align: left;
    }

    .weekly-sub {
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.04em;
      line-height: 1.6;
      width: 100%;
      text-align: left;
    }

    /* ======================== STREAK ======================== */
    .streak-box {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 12px 14px;
      margin-bottom: 10px;
      position: relative;
      overflow: hidden;
    }

    .streak-box.alive {
      border-color: rgba(139,58,58,0.35);
      background: rgba(139,58,58,0.07);
    }

    .streak-box.alive::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(139,58,58,0.04), transparent);
      animation: shimmer 2.5s ease infinite;
    }

    @keyframes shimmer {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }

    .streak-flame {
      font-size: 22px;
      line-height: 1;
      filter: grayscale(1) opacity(0.3);
      transition: filter 0.4s;
      flex-shrink: 0;
    }

    .streak-box.alive .streak-flame {
      filter: none;
      animation: flamePulse 1.5s ease infinite;
    }

    @keyframes flamePulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.12); }
    }

    .streak-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px;
      font-weight: 600;
      color: var(--text);
      line-height: 1;
    }

    .streak-box.alive .streak-num {
      color: var(--accent);
    }

    .streak-label {
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted2);
      margin-top: 3px;
    }

    /* Toast notification */
    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(60px);
      background: var(--surface2);
      border: 1px solid rgba(139,58,58,0.3);
      border-radius: 4px;
      padding: 12px 20px;
      font-size: 12px;
      color: var(--text);
      letter-spacing: 0.04em;
      z-index: 9000;
      transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s;
      opacity: 0;
      white-space: nowrap;
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }

    /* ======================== MOBILE OVERLAY SIDEBAR ======================== */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(14,14,18,0.7);
      z-index: 100;
    }

    /* ======================== RESPONSIVE ======================== */
    @media (max-width: 680px) {
      .app {
        grid-template-columns: 1fr;
      }

      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        width: 280px;
        z-index: 200;
        transform: translateX(-100%);
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .sidebar-overlay {
        display: block;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s;
      }

      .sidebar-overlay.open {
        opacity: 1;
        pointer-events: all;
      }

      .menu-btn {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .chat-area {
        padding: 20px 16px;
        gap: 18px;
      }

      .input-zone {
        padding: 12px 16px 16px;
      }

      .topbar {
        padding: 12px 16px;
      }

      .msg {
        max-width: 100%;
      }

      .welcome {
        padding: 24px 16px;
      }

      .starters {
        max-width: 100%;
      }
    }

    @media (max-width: 400px) {
      .msg-bubble {
        font-size: 12px;
        padding: 12px 14px;
      }

      .input-field {
        font-size: 12px;
      }
    }
  </style>
</head>
<body>

<!-- Mobile sidebar overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<div class="app">
  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="logo">Vein<div class="logo-dot"></div></div>
      <div class="logo-sub">Think deeper</div>
    </div>

    <div class="sidebar-scroll">
      <div class="sidebar-section">
        <div class="sidebar-label">Modalità</div>
        <div class="mode-list">
          <button class="mode-btn active" onclick="setMode('socratico'); closeSidebar()">
            <span class="mode-icon">◈</span> Dialogo socratico
          </button>
          <button class="mode-btn" onclick="setMode('idea'); closeSidebar()">
            <span class="mode-icon">◎</span> Esplora un'idea
          </button>
          <button class="mode-btn" onclick="setMode('decisione'); closeSidebar()">
            <span class="mode-icon">⊞</span> Analizza una decisione
          </button>
          <button class="mode-btn" onclick="setMode('tensioni'); closeSidebar()">
            <span class="mode-icon">⟳</span> Mappa tensioni
          </button>
          <div class="mode-devil-sep"></div>
          <button class="mode-btn devil" onclick="setMode('diavolo'); closeSidebar()">
            <span class="mode-icon">⚔</span> Avvocato del diavolo
          </button>
        </div>
      </div>

      <div class="sidebar-divider"></div>

      <div class="sidebar-section">
        <div class="sidebar-label">Sessione</div>
        <div class="session-summary" id="sessionSummary">
          Inizia una conversazione per vedere i temi emergenti.
        </div>
      </div>
    </div>

    <div class="sidebar-footer">
      <div class="streak-box" id="streakBox">
        <div class="streak-flame" id="streakFlame">🔥</div>
        <div class="streak-info">
          <div class="streak-num" id="streakNum">0</div>
          <div class="streak-label">giorni consecutivi</div>
        </div>
      </div>
      <div class="stat-grid">
        <div class="stat-box">
          <div class="stat-label">Scambi</div>
          <div class="stat-val" id="exchangeCount">0</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">Profondità</div>
          <div class="stat-val" id="depthLevel" style="font-size:12px; margin-top:3px">—</div>
        </div>
      </div>
      <div class="depth-bar-wrap">
        <div class="depth-bar-header">
          <span class="depth-bar-label">Profondità accumulata</span>
          <span class="depth-bar-val" id="totalSessions">0 sessioni</span>
        </div>
        <div class="depth-bar-track">
          <div class="depth-bar-fill" id="depthBarFill"></div>
        </div>
        <div class="depth-bar-milestone" id="depthMilestone"></div>
      </div>
      <div class="footer-btns">
        <button class="footer-btn" onclick="resetSession()">↺ Nuova sessione</button>
        <button class="footer-btn" style="color:rgba(139,58,58,0.45); border-color:rgba(139,58,58,0.15)" onclick="resetKey()">⚿ Cambia API key</button>
      </div>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <div class="topbar">
      <div class="topbar-left">
        <button class="menu-btn" onclick="openSidebar()" aria-label="Menu">☰</button>
        <div class="topbar-info">
          <div class="topbar-title" id="topbarTitle">Dialogo Socratico</div>
          <div class="topbar-sub" id="topbarSub">Vein ti fa le domande giuste</div>
        </div>
      </div>
      <div class="status-pill">
        <div class="status-dot"></div>
        Attivo
      </div>
    </div>

    <div class="chat-area" id="chatArea">
      <div class="welcome" id="welcomeState">
        <div class="welcome-symbol">V</div>
        <h2 class="welcome-title">Cosa hai in mente?</h2>
        <p class="welcome-sub">Condividi un'idea, una decisione, qualcosa che hai letto. Vein inizierà a farti domande per aiutarti a pensarci davvero.</p>
        <div class="starters">
          <button class="starter-btn" onclick="useStarter(this)">
            <div class="starter-tag">Idea</div>
            Sto pensando di cambiare lavoro ma non sono sicuro se sia il momento giusto
          </button>
          <button class="starter-btn" onclick="useStarter(this)">
            <div class="starter-tag">Lettura</div>
            Ho letto un articolo sull'importanza del deep work ma non riesco ad applicarlo
          </button>
          <button class="starter-btn" onclick="useStarter(this)">
            <div class="starter-tag">Decisione</div>
            Devo scegliere tra due opportunità e non riesco a capire quale sia quella giusta
          </button>
        </div>
      </div>
    </div>

    <div class="input-zone">
      <div class="input-row">
        <textarea
          class="input-field"
          id="chatInput"
          placeholder="Scrivi un pensiero, un'idea, una decisione..."
          rows="1"
          onkeydown="handleKey(event)"
          oninput="autoResize(this)"
        ></textarea>
        <button class="send-btn" id="sendBtn" onclick="sendMessage()">↑</button>
      </div>
      <div class="voice-row">
        <button class="mic-btn" id="micBtn" onclick="toggleMic()" title="Parla con Vein">🎤</button>
        <span class="mic-label" id="micLabel">Tieni premuto o clicca per parlare</span>
        <button class="voice-toggle" id="voiceToggle" onclick="toggleVoiceReply()" title="Risposta vocale di Vein">
          <span class="toggle-icon">🔊</span>
          <span class="toggle-label" id="voiceToggleLabel">Voce off</span>
        </button>
      </div>
      <div class="input-hint">Enter per inviare · Shift+Enter per andare a capo</div>
    </div>
  </main>
</div>

<!-- API Key Overlay -->
<div class="overlay" id="keyOverlay">
  <div class="overlay-card">
    <div class="overlay-logo">Vein<span>.</span></div>
    <div class="overlay-title">Connetti il tuo account</div>
    <div class="overlay-sub">Inserisci la tua API key di Anthropic per attivare il dialogo. Viene salvata solo nel tuo browser, non viene condivisa con nessuno.</div>
    <input type="password" class="overlay-input" id="keyInput" placeholder="sk-ant-api03-..." autocomplete="off" onkeydown="if(event.key==='Enter') saveKey()"/>
    <div class="overlay-error" id="keyError">La key deve iniziare con sk-ant-</div>
    <button class="overlay-btn" onclick="saveKey()">ATTIVA VEIN →</button>
    <a class="overlay-link" href="https://console.anthropic.com" target="_blank">Ottieni una key su console.anthropic.com →</a>
  </div>
</div>

<!-- Insight Modal -->
<div class="overlay" id="insightOverlay">
  <div class="overlay-card insight-card">
    <div class="insight-header">
      <div class="insight-week">Insight settimanale</div>
      <div class="insight-streak" id="insightStreakLabel"></div>
    </div>
    <div class="insight-body" id="insightBody">
      <div class="insight-loading">
        <div class="typing-dots" style="justify-content:center">
          <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
        </div>
      </div>
    </div>
    <button class="overlay-btn" onclick="closeInsight()" style="margin-top:8px">Chiudi</button>
  </div>
</div>

<!-- Weekly Question Modal -->
<div class="overlay" id="weeklyOverlay">
  <div class="overlay-card">
    <div class="insight-week" style="font-size:9px; letter-spacing:0.2em; color:var(--muted2); text-transform:uppercase;">Domanda della settimana</div>
    <div class="weekly-q" id="weeklyQuestion">...</div>
    <div class="weekly-sub">Riservata a chi ha completato 3+ sessioni questa settimana.</div>
    <button class="overlay-btn" onclick="startWeeklyQuestion()">Inizia con questa domanda →</button>
    <button class="footer-btn" onclick="document.getElementById('weeklyOverlay').classList.remove('open')" style="width:100%; text-align:center; margin-top:6px">Magari dopo</button>
  </div>
</div>

<script>
  let conversationHistory = [];
  let exchangeCount = 0;
  let currentMode = 'socratico';
  let isLoading = false;
  let API_KEY = localStorage.getItem('vein-api-key') || '';

  if (!API_KEY) showKeyOverlay();

  // ======================== STREAK ========================
  function getStreak() {
    const data = JSON.parse(localStorage.getItem('vein-streak') || '{"count":0,"lastDate":null}');
    return data;
  }

  function markSessionToday() {
    const today = new Date().toDateString();
    const data = getStreak();
    if (data.lastDate === today) return; // already counted today

    const yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    const yStr = yesterday.toDateString();

    if (data.lastDate === yStr) {
      // consecutive day
      data.count += 1;
    } else if (data.lastDate !== today) {
      // streak broken or first time
      data.count = 1;
    }
    data.lastDate = today;
    localStorage.setItem('vein-streak', JSON.stringify(data));
    renderStreak(data);

    if (data.count > 1) {
      showToast(`🔥 ${data.count} giorni consecutivi — ottimo lavoro.`);
    } else if (data.count === 1) {
      showToast('Sessione registrata. Torna domani per iniziare la tua serie.');
    }
  }

  function renderStreak(data) {
    if (!data) data = getStreak();
    const box = document.getElementById('streakBox');
    document.getElementById('streakNum').textContent = data.count;
    if (data.count > 0) {
      box.classList.add('alive');
    } else {
      box.classList.remove('alive');
    }
  }

  function showToast(msg) {
    let toast = document.getElementById('veinToast');
    if (!toast) {
      toast = document.createElement('div');
      toast.className = 'toast';
      toast.id = 'veinToast';
      document.body.appendChild(toast);
    }
    toast.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3500);
  }

  // Init streak on load
  renderStreak();

  // ======================== DEPTH ACCUMULATION ========================
  function getLifetimeStats() {
    return JSON.parse(localStorage.getItem('vein-lifetime') || '{"totalSessions":0,"totalExchanges":0}');
  }

  function saveLifetimeStats(stats) {
    localStorage.setItem('vein-lifetime', JSON.stringify(stats));
  }

  function incrementLifetimeSession() {
    const stats = getLifetimeStats();
    stats.totalSessions += 1;
    stats.totalExchanges += exchangeCount;
    saveLifetimeStats(stats);
    renderDepthBar(stats);
  }

  function renderDepthBar(stats) {
    if (!stats) stats = getLifetimeStats();
    const milestones = [1, 5, 10, 25, 50, 100];
    const labels = ['Prima sessione', '5 sessioni', '10 sessioni — esploratore', '25 sessioni — pensatore', '50 sessioni — profondo', '100 sessioni — maestro'];

    document.getElementById('totalSessions').textContent = `${stats.totalSessions} sessioni`;

    // Find current milestone bracket
    let nextMilestone = milestones.find(m => m > stats.totalSessions) || 100;
    let prevMilestone = 0;
    for (let i = milestones.length - 1; i >= 0; i--) {
      if (milestones[i] <= stats.totalSessions) { prevMilestone = milestones[i]; break; }
    }

    const progress = nextMilestone === prevMilestone ? 100 :
      ((stats.totalSessions - prevMilestone) / (nextMilestone - prevMilestone)) * 100;

    document.getElementById('depthBarFill').style.width = Math.min(progress, 100) + '%';

    // Milestone label
    const milestoneEl = document.getElementById('depthMilestone');
    const reachedIdx = milestones.lastIndexOf(stats.totalSessions);
    if (reachedIdx >= 0) {
      milestoneEl.textContent = '✦ ' + labels[reachedIdx];
    } else {
      milestoneEl.textContent = nextMilestone > stats.totalSessions
        ? `${nextMilestone - stats.totalSessions} sessioni al prossimo livello`
        : '';
    }
  }

  // Init depth bar
  renderDepthBar();

  // ======================== WEEKLY QUESTION ========================
  const WEEKLY_QUESTIONS = [
    "Qual è la decisione che continui a rimandare, e cosa ti dice questo rimando?",
    "Se potessi cambiare una sola cosa nel tuo modo di lavorare, quale sarebbe?",
    "Dove stai investendo energia in qualcosa che non ti appartiene davvero?",
    "Qual è la conversazione che hai evitato questa settimana, e perché?",
    "Cosa stai ottimizzando nella tua vita che forse non vale la pena ottimizzare?",
    "Dove la tua identità professionale ti limita invece di liberarti?",
    "Qual è l'assunzione più antica che porti con te nel lavoro?",
    "Cosa succederebbe se smettessi di fare la cosa che ti occupa più tempo?"
  ];

  function getWeeklyData() {
    return JSON.parse(localStorage.getItem('vein-weekly') || '{"weekKey":"","sessionsThisWeek":0,"questionShown":false,"lastQuestion":""}');
  }

  function getWeekKey() {
    const d = new Date();
    const start = new Date(d.getFullYear(), 0, 1);
    const week = Math.ceil(((d - start) / 86400000 + start.getDay() + 1) / 7);
    return `${d.getFullYear()}-W${week}`;
  }

  function trackWeeklySession() {
    const weekKey = getWeekKey();
    const data = getWeeklyData();

    if (data.weekKey !== weekKey) {
      data.weekKey = weekKey;
      data.sessionsThisWeek = 1;
      data.questionShown = false;
    } else {
      data.sessionsThisWeek += 1;
    }

    localStorage.setItem('vein-weekly', JSON.stringify(data));

    // Show weekly question at exactly 3 sessions if not shown yet
    if (data.sessionsThisWeek === 3 && !data.questionShown) {
      showWeeklyQuestion(data);
    }
  }

  function showWeeklyQuestion(data) {
    const weekKey = getWeekKey();
    // Pick question based on week number for consistency
    const weekNum = parseInt(weekKey.split('W')[1]) || 0;
    const q = WEEKLY_QUESTIONS[weekNum % WEEKLY_QUESTIONS.length];

    data.questionShown = true;
    data.lastQuestion = q;
    localStorage.setItem('vein-weekly', JSON.stringify(data));

    document.getElementById('weeklyQuestion').textContent = `"${q}"`;
    setTimeout(() => {
      document.getElementById('weeklyOverlay').classList.add('open');
    }, 1200);
  }

  function startWeeklyQuestion() {
    const data = getWeeklyData();
    const q = data.lastQuestion;
    document.getElementById('weeklyOverlay').classList.remove('open');
    if (q) {
      document.getElementById('chatInput').value = q;
      autoResize(document.getElementById('chatInput'));
      document.getElementById('chatInput').focus();
    }
  }

  // ======================== WEEKLY INSIGHT ========================
  function checkWeeklyInsight() {
    const streak = getStreak();
    if (streak.count > 0 && streak.count % 7 === 0) {
      // Check if we already showed insight for this streak count
      const shown = localStorage.getItem('vein-insight-shown');
      if (shown !== String(streak.count)) {
        localStorage.setItem('vein-insight-shown', String(streak.count));
        setTimeout(() => generateWeeklyInsight(streak.count), 2000);
      }
    }
  }

  async function generateWeeklyInsight(streakCount) {
    const stats = getLifetimeStats();
    document.getElementById('insightStreakLabel').textContent = `🔥 ${streakCount} giorni`;
    document.getElementById('insightOverlay').classList.add('open');

    // Use last session history if available, otherwise generic
    const historyContext = conversationHistory.length > 2
      ? `Ultime conversazioni dell'utente: ${JSON.stringify(conversationHistory.slice(-8))}`
      : `L'utente ha completato ${stats.totalSessions} sessioni di riflessione.`;

    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: getHeaders(),
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 300,
          messages: [{
            role: 'user',
            content: `${historyContext}
            
Scrivi un insight settimanale personale per questo utente. Tono: riflessivo, diretto, non banale. Come se fosse una nota privata da un mentore silenzioso. Max 3 frasi. Niente introduzioni. Inizia direttamente con l'osservazione. In italiano.`
          }]
        })
      });
      const d = await res.json();
      const insight = d.content?.[0]?.text || '';
      if (insight) {
        document.getElementById('insightBody').innerHTML = `<p>${insight}</p>`;
      }
    } catch(e) {
      document.getElementById('insightBody').innerHTML = `<p style="color:var(--muted)">Non è stato possibile generare l'insight. Riprova più tardi.</p>`;
    }
  }

  function closeInsight() {
    document.getElementById('insightOverlay').classList.remove('open');
    document.getElementById('insightBody').innerHTML = `<div class="insight-loading"><div class="typing-dots" style="justify-content:center"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>`;
  }

  // ======================== SIDEBAR MOBILE ========================
  function openSidebar() {
    document.getElementById('sidebar').classList.add('open');
    document.getElementById('sidebarOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  // ======================== KEY MANAGEMENT ========================
  function showKeyOverlay() {
    document.getElementById('keyOverlay').classList.add('open');
  }

  function saveKey() {
    const k = document.getElementById('keyInput').value.trim();
    if (!k.startsWith('sk-ant-')) {
      document.getElementById('keyError').style.display = 'block';
      return;
    }
    API_KEY = k;
    localStorage.setItem('vein-api-key', k);
    document.getElementById('keyOverlay').classList.remove('open');
  }

  function resetKey() {
    localStorage.removeItem('vein-api-key');
    API_KEY = '';
    document.getElementById('keyInput').value = '';
    document.getElementById('keyError').style.display = 'none';
    showKeyOverlay();
  }

  function getHeaders() {
    return {
      'Content-Type': 'application/json',
      'x-api-key': API_KEY,
      'anthropic-version': '2023-06-01',
      'anthropic-dangerous-direct-browser-access': 'true'
    };
  }

  // ======================== PROMPTS ========================
  const SYSTEM_PROMPT = `Sei Vein, un assistente di riflessione personale che usa il metodo socratico per aiutare professionisti e manager a pensare in profondità.

Il tuo obiettivo non è dare risposte o consigli, ma fare domande potenti che aiutino l'utente a pensare meglio.

Regole fondamentali:
1. Fai UNA sola domanda alla volta — mai due o tre
2. Le domande devono essere scomode nel modo giusto: penetranti, specifiche, che smontano le assunzioni
3. Non dare consigli, non validare, non rassicurare — fai domande
4. Rispecchia le parole dell'utente nella tua domanda per mostrare che hai ascoltato
5. Man mano che la conversazione avanza, vai sempre più in profondità — non restare in superficie
6. Ogni 3-4 scambi, fai una domanda che connette ciò che è emerso in precedenza
7. Rispondi sempre in italiano
8. Sii diretto e conciso — niente preamboli, niente "ottima riflessione", niente lusinghe
9. A volte, dopo la domanda, aggiungi una breve osservazione (max 1 frase) che nomina la tensione o il pattern che stai vedendo — inizia sempre con "Noto che..." o "Sembra che..."

Modalità attuale: PLACEHOLDER
Inizia sempre rispondendo direttamente con una domanda, senza presentarti.`;

  const MODE_PROMPTS = {
    socratico: 'Dialogo socratico — Fai domande che smontano le assunzioni e vanno in profondità.',
    idea: "Esplora un'idea — Aiuta a sviluppare, testare e rafforzare un'idea attraverso domande.",
    decisione: 'Analizza una decisione — Aiuta a chiarire criteri, valori e trade-off nascosti.',
    tensioni: "Mappa tensioni — Identifica le contraddizioni e i punti ciechi nel pensiero dell'utente.",
    diavolo: `Avvocato del diavolo — Regole completamente diverse:
1. NON fare domande. Prendi la posizione OPPOSTA a quella dell'utente e argomentala con forza.
2. Sei brillante, diretto, provocatorio — ma mai maleducato.
3. Smonta le sue idee con argomenti concreti, dati, esempi controfattuali.
4. Se l'utente si difende bene, concedi il punto e attacca da un altro angolo.
5. Il tuo obiettivo è costringerlo a rafforzare o abbandonare le sue idee sotto pressione.
6. Inizia sempre con "Al contrario —" o "Non sono d'accordo —" seguito dal tuo argomento opposto.
7. Sii conciso e tagliente. Max 3 frasi per risposta.
8. Rispondi in italiano.`
  };

  const MODE_LABELS = {
    socratico: { title: 'Dialogo Socratico', sub: 'Vein ti fa le domande giuste' },
    idea: { title: "Esplora un'Idea", sub: 'Sviluppa e testa la tua idea' },
    decisione: { title: 'Analisi Decisione', sub: 'Chiarisci criteri e trade-off' },
    tensioni: { title: 'Mappa Tensioni', sub: 'Trova le contraddizioni nel tuo pensiero' },
    diavolo: { title: '⚔ Avvocato del Diavolo', sub: 'Vein prende la posizione opposta alla tua' }
  };

  // ======================== MODE ========================
  function setMode(mode) {
    currentMode = mode;
    const allModes = ['socratico','idea','decisione','tensioni','diavolo'];
    document.querySelectorAll('.mode-btn').forEach((b, i) => {
      b.classList.toggle('active', allModes[i] === mode);
    });
    const l = MODE_LABELS[mode];
    document.getElementById('topbarTitle').textContent = l.title;
    document.getElementById('topbarSub').textContent = l.sub;
  }

  // ======================== INPUT ========================
  function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 140) + 'px';
  }

  function handleKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  }

  // ======================== VOICE INPUT ========================
  let recognition = null;
  let isListening = false;
  let voiceReplyOn = false;

  function initRecognition() {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) return null;
    const r = new SR();
    r.lang = 'it-IT';
    r.interimResults = true;
    r.continuous = false;

    r.onstart = () => {
      isListening = true;
      document.getElementById('micBtn').classList.add('listening');
      document.getElementById('micBtn').textContent = '⏹';
      const lbl = document.getElementById('micLabel');
      lbl.textContent = 'In ascolto…';
      lbl.classList.add('active');
    };

    r.onresult = (e) => {
      let transcript = '';
      for (let i = e.resultIndex; i < e.results.length; i++) {
        transcript += e.results[i][0].transcript;
      }
      const input = document.getElementById('chatInput');
      input.value = transcript;
      autoResize(input);
    };

    r.onend = () => {
      isListening = false;
      document.getElementById('micBtn').classList.remove('listening');
      document.getElementById('micBtn').textContent = '🎤';
      const lbl = document.getElementById('micLabel');
      const input = document.getElementById('chatInput');
      if (input.value.trim()) {
        lbl.textContent = 'Messaggio pronto — premi ↑ per inviare';
        lbl.classList.add('active');
        // auto-send after short pause
        setTimeout(() => {
          if (input.value.trim()) {
            sendMessage();
            lbl.textContent = 'Tieni premuto o clicca per parlare';
            lbl.classList.remove('active');
          }
        }, 900);
      } else {
        lbl.textContent = 'Tieni premuto o clicca per parlare';
        lbl.classList.remove('active');
      }
    };

    r.onerror = (e) => {
      isListening = false;
      document.getElementById('micBtn').classList.remove('listening');
      document.getElementById('micBtn').textContent = '🎤';
      const lbl = document.getElementById('micLabel');
      if (e.error === 'not-allowed') {
        lbl.textContent = 'Permesso microfono negato';
      } else {
        lbl.textContent = 'Errore — riprova';
      }
      lbl.classList.remove('active');
    };

    return r;
  }

  function toggleMic() {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) {
      document.getElementById('micLabel').textContent = 'Riconoscimento vocale non supportato su questo browser';
      return;
    }
    if (isListening) {
      if (recognition) recognition.stop();
      return;
    }
    recognition = initRecognition();
    if (recognition) recognition.start();
  }

  // ======================== VOICE REPLY ========================
  let currentUtterance = null;

  function toggleVoiceReply() {
    voiceReplyOn = !voiceReplyOn;
    const btn = document.getElementById('voiceToggle');
    const lbl = document.getElementById('voiceToggleLabel');
    if (voiceReplyOn) {
      btn.classList.add('on');
      lbl.textContent = 'Voce on';
    } else {
      btn.classList.remove('on');
      lbl.textContent = 'Voce off';
      if (currentUtterance) window.speechSynthesis.cancel();
    }
  }

  function speakText(text) {
    if (!voiceReplyOn) return;
    if (!window.speechSynthesis) return;
    window.speechSynthesis.cancel();
    // Strip markdown-like chars
    const clean = text.replace(/[*_`#◈◎⊞⟳⚔]/g, '').trim();
    const utt = new SpeechSynthesisUtterance(clean);
    utt.lang = 'it-IT';
    utt.rate = 0.92;
    utt.pitch = 0.95;
    // prefer a female voice if available
    const voices = window.speechSynthesis.getVoices();
    const ita = voices.find(v => v.lang.startsWith('it') && v.name.toLowerCase().includes('female'))
              || voices.find(v => v.lang.startsWith('it'))
              || null;
    if (ita) utt.voice = ita;
    currentUtterance = utt;
    window.speechSynthesis.speak(utt);
  }

  // Preload voices (Chrome requires this)
  if (window.speechSynthesis) {
    window.speechSynthesis.getVoices();
    window.speechSynthesis.onvoiceschanged = () => window.speechSynthesis.getVoices();
  }

  function useStarter(btn) {
    const label = btn.querySelector('.starter-tag');
    const text = btn.textContent.replace(label.textContent, '').trim();
    document.getElementById('chatInput').value = text;
    autoResize(document.getElementById('chatInput'));
    sendMessage();
  }

  // ======================== MESSAGES ========================
  function hideWelcome() {
    const w = document.getElementById('welcomeState');
    if (w) w.remove();
  }

  function appendMessage(role, text) {
    hideWelcome();
    const chatArea = document.getElementById('chatArea');
    const isVein = role === 'vein';

    const msg = document.createElement('div');
    msg.className = `msg ${isVein ? 'vein' : 'user'}`;

    let mainText = text;
    let observationText = '';

    if (isVein) {
      const match = text.match(/(Noto che[^.!?]*[.!?]|Sembra che[^.!?]*[.!?])/);
      if (match) {
        mainText = text.replace(match[0], '').trim();
        observationText = match[0];
      }
    }

    msg.innerHTML = `
      <div class="msg-avatar">${isVein ? 'V' : 'Tu'}</div>
      <div class="msg-body">
        <div class="msg-name">${isVein ? 'Vein' : 'Tu'}</div>
        <div class="msg-bubble">
          ${mainText}
          ${observationText ? `<span class="observation-pill">${observationText}</span>` : ''}
        </div>
      </div>
    `;

    chatArea.appendChild(msg);
    chatArea.scrollTop = chatArea.scrollHeight;
    if (isVein) speakText(mainText);
  }

  function showTyping() {
    const chatArea = document.getElementById('chatArea');
    const el = document.createElement('div');
    el.className = 'msg vein';
    el.id = 'typingIndicator';
    el.innerHTML = `
      <div class="msg-avatar">V</div>
      <div class="msg-body">
        <div class="msg-name">Vein</div>
        <div class="typing-dots">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      </div>
    `;
    chatArea.appendChild(el);
    chatArea.scrollTop = chatArea.scrollHeight;
  }

  function hideTyping() {
    const t = document.getElementById('typingIndicator');
    if (t) t.remove();
  }

  function updateStats() {
    document.getElementById('exchangeCount').textContent = exchangeCount;
    const depths = ['—', 'Superficie', 'Mezzo', 'Profonda', 'Fondo'];
    document.getElementById('depthLevel').textContent = depths[Math.min(Math.floor(exchangeCount / 2), 4)];
  }

  // ======================== API ========================
  async function sendMessage() {
    const input = document.getElementById('chatInput');
    const text = input.value.trim();
    if (!text || isLoading) return;

    input.value = '';
    input.style.height = 'auto';
    isLoading = true;
    document.getElementById('sendBtn').disabled = true;

    appendMessage('user', text);
    conversationHistory.push({ role: 'user', content: text });
    exchangeCount++;
    updateStats();
    showTyping();

    try {
      const system = SYSTEM_PROMPT.replace('PLACEHOLDER', MODE_PROMPTS[currentMode]);

      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: getHeaders(),
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          system,
          messages: conversationHistory
        })
      });

      const data = await response.json();
      hideTyping();

      const reply = data.content?.map(b => b.text || '').join('') || 'Non ho ricevuto una risposta.';
      conversationHistory.push({ role: 'assistant', content: reply });
      appendMessage('vein', reply);

      // Mark streak on first real exchange
      if (exchangeCount === 1) {
        markSessionToday();
        trackWeeklySession();
      }

      // On session end (5+ exchanges), accumulate depth
      if (exchangeCount === 5) {
        incrementLifetimeSession();
        checkWeeklyInsight();
      }

      if (exchangeCount >= 2) updateSessionSummary();

    } catch (err) {
      hideTyping();
      appendMessage('vein', 'Errore di connessione. Controlla la tua API key e riprova.');
    }

    isLoading = false;
    document.getElementById('sendBtn').disabled = false;
    input.focus();
  }

  async function updateSessionSummary() {
    if (conversationHistory.length < 4) return;
    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: getHeaders(),
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 120,
          messages: [{
            role: 'user',
            content: `Questa è una conversazione di riflessione: ${JSON.stringify(conversationHistory.slice(-6))}. In 2 righe max, nomina il tema centrale e una tensione emergente. Sii sintetico e diretto. Risposta in italiano.`
          }]
        })
      });
      const d = await res.json();
      const summary = d.content?.[0]?.text || '';
      if (summary) document.getElementById('sessionSummary').textContent = summary;
    } catch(e) {}
  }

  // ======================== RESET ========================
  function resetSession() {
    // Save depth if session had exchanges
    if (exchangeCount > 0) {
      incrementLifetimeSession();
      checkWeeklyInsight();
    }
    conversationHistory = [];
    exchangeCount = 0;
    setMode('socratico');
    document.getElementById('sessionSummary').textContent = 'Inizia una conversazione per vedere i temi emergenti.';
    updateStats();

    document.getElementById('chatArea').innerHTML = `
      <div class="welcome" id="welcomeState">
        <div class="welcome-symbol">V</div>
        <h2 class="welcome-title">Cosa hai in mente?</h2>
        <p class="welcome-sub">Condividi un'idea, una decisione, qualcosa che hai letto. Vein inizierà a farti domande per aiutarti a pensarci davvero.</p>
        <div class="starters">
          <button class="starter-btn" onclick="useStarter(this)">
            <div class="starter-tag">Idea</div>
            Sto pensando di cambiare lavoro ma non sono sicuro se sia il momento giusto
          </button>
          <button class="starter-btn" onclick="useStarter(this)">
            <div class="starter-tag">Lettura</div>
            Ho letto un articolo sull'importanza del deep work ma non riesco ad applicarlo
          </button>
          <button class="starter-btn" onclick="useStarter(this)">
            <div class="starter-tag">Decisione</div>
            Devo scegliere tra due opportunità e non riesco a capire quale sia quella giusta
          </button>
        </div>
      </div>
    `;
    closeSidebar();
  }
</script>
</body>
